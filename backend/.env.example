# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stima

# Auth
SECRET_KEY=replace-with-strong-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie config
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# Leave empty locally to disable host-header enforcement.
ALLOWED_HOSTS=
# Keep false unless the app itself should redirect plain HTTP requests.
ENABLE_HTTPS_REDIRECT=false
# Comma-separated proxy IPs/CIDRs allowed to set X-Forwarded-* headers.
TRUSTED_PROXY_IPS=
# Use a non-production bucket locally.
GCS_BUCKET_NAME=your-local-or-dev-bucket-name

# AI model selection
EXTRACTION_MODEL=claude-haiku-4-5-20251001
TRANSCRIPTION_MODEL=whisper-1

# Sentry Monitoring
SENTRY_DSN=
ADMIN_API_KEY=

# Resend Email
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
