# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stima

# Auth
SECRET_KEY=replace-with-strong-random-value
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cookie config
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
# Optional locally: leave unset for in-memory rate limits / extraction quota.
# With docker compose up redis: redis://localhost:6379/0
REDIS_URL=
# Dedicated Redis DB used exclusively by the test suite. When set, tests use real
# Redis-backed rate limiting and quota state instead of the in-memory fallback.
# Recommended: docker compose up redis, then set TEST_REDIS_URL=redis://localhost:6379/15
# (DB 15 is a separate database from the dev DB 0, so test FLUSHDB never touches dev data)
TEST_REDIS_URL=
# Optional; defaults to stima. Shared Upstash deployments should use a distinct app prefix.
REDIS_KEY_PREFIX=stima
RATE_LIMIT_HEADERS_ENABLED=false

# Optional rate-limit overrides
AUTH_REGISTER_RATE_LIMIT=3/hour
AUTH_LOGIN_RATE_LIMIT=5/minute
AUTH_REFRESH_RATE_LIMIT=10/minute
AUTH_LOGOUT_RATE_LIMIT=10/minute
ADMIN_EVENTS_RATE_LIMIT=10/minute
PUBLIC_DOCUMENT_FETCH_RATE_LIMIT=60/minute
PUBLIC_LOGO_FETCH_RATE_LIMIT=120/minute
QUOTE_TEXT_EXTRACTION_RATE_LIMIT=15/hour
QUOTE_AUDIO_CAPTURE_RATE_LIMIT=10/hour
QUOTE_COMBINED_EXTRACT_RATE_LIMIT=10/hour
AUTHENTICATED_PDF_GENERATION_RATE_LIMIT=20/hour
QUOTE_EMAIL_SEND_RATE_LIMIT=10/day
INVOICE_EMAIL_SEND_RATE_LIMIT=10/day
QUOTE_EMAIL_DUPLICATE_SEND_WINDOW_SECONDS=60
INVOICE_EMAIL_DUPLICATE_SEND_WINDOW_SECONDS=60
EXTRACTION_DAILY_QUOTA=40
EXTRACTION_CONCURRENCY_LIMIT=2
EXTRACTION_CONCURRENCY_TTL_SECONDS=900
# ARQ worker Redis poll interval. Lower values reduce job startup latency but increase
# Redis command usage. At 15s an idle worker costs ~173k commands/month on Upstash.
WORKER_POLL_DELAY_SECONDS=15
ALLOWED_ORIGINS=http://localhost:5173
# Leave empty locally to disable host-header enforcement.
ALLOWED_HOSTS=
# Keep false unless the app itself should redirect plain HTTP requests.
ENABLE_HTTPS_REDIRECT=false
# Comma-separated proxy IPs/CIDRs allowed to set X-Forwarded-* headers.
TRUSTED_PROXY_IPS=
# Use a non-production bucket locally.
GCS_BUCKET_NAME=your-local-or-dev-bucket-name

# AI model selection
EXTRACTION_MODEL=claude-haiku-4-5-20251001
# Optional fallback model used only after primary extraction attempts are exhausted.
EXTRACTION_FALLBACK_MODEL=
EXTRACTION_PRIMARY_PROMPT_VARIANT=primary_default
EXTRACTION_FALLBACK_PROMPT_VARIANT=fallback_default
TRANSCRIPTION_MODEL=whisper-1

# Sentry Monitoring
SENTRY_DSN=
ADMIN_API_KEY=

# Resend Email
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
